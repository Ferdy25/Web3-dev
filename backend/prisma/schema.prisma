generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:postgres@localhost:5432/sekolah?schema=public"
}

model Institusi {
  id        Int      @id @default(autoincrement())
  nama      String   @unique
  alamat    String?
  siswa     Siswa[]
  guru      Guru[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Siswa {
  id           Int       @id @default(autoincrement())
  alamat       String    @unique
  nis          String
  nama         String
  aktif        Boolean   @default(true)
  institusiId  Int
  institusi    Institusi @relation(fields: [institusiId], references: [id])
  nilai        Nilai[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Guru {
  id           Int       @id @default(autoincrement())
  alamat       String    @unique  // alamat wallet
  nip          String    @unique
  nama         String
  institusiId  Int
  institusi    Institusi @relation(fields: [institusiId], references: [id])
  mataPelajaran String[] // array string, bisa juga bikin tabel terpisah
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Nilai {
  // tetap seperti sebelumnya
  id          String   @id @default(uuid())
  idNilai     String   @unique
  alamatSiswa String
  siswa       Siswa    @relation(fields: [alamatSiswa], references: [alamat])
  mapel       String
  nilaiAngka  Int
  predikat    String
  timestamp   Int
  createdAt   DateTime @default(now())
}